# Kontaktformular — E-Mail-Versand via Resend (https://resend.com)
# Ohne RESEND_API_KEY funktioniert das Formular trotzdem; Anfragen werden
# dann in der Server-Konsole ausgegeben (Dev-Fallback).

RESEND_API_KEY=
# Empfänger der Anfragen
CONTACT_TO_EMAIL=kontakt@milvamaerz.de
# Absender (muss bei Resend verifiziert sein; Standard nutzt resend.dev zum Testen)
CONTACT_FROM_EMAIL=Website <onboarding@resend.dev>
